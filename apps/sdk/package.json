{
  "name": "@reaatech/postmill-sdk",
  "version": "0.1.0",
  "description": "The ultimate social media scheduling tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "release": "tsup && pnpm publish --access public",
