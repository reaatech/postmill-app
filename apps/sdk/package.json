  "files": [
    "dist"
  ],
  "keywords": [
    "social media",
    "scheduling tool",
    "social media scheduling tool"
  ],
  "author": "Nevo David",
  "license": "AGPL-3.0",
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
