{
  "name": "@reaatech/postmill-sdk",
  "version": "0.1.0",
  "description": "The ultimate social media scheduling tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "release": "tsup && pnpm publish --access public",
    "release:dry": "tsup && pnpm publish --access public --dry-run --no-git-checks"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "social media",
    "scheduling tool",
    "social media scheduling tool"
  ],
  "author": "Nevo David",
  "license": "AGPL-3.0",
  "dependencies": {
    "@gitroom/nestjs-libraries": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.5.1",
    "typescript": "5.5.4",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.12.0 <23.0.0"
  }
}
