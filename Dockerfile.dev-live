# Toolchain-only image for live-reload development.
# The source is bind-mounted at runtime (see docker-compose.dev-app.yaml) — nothing
# is COPYed in, so editing files on the host triggers nest/next watch inside the container.
FROM node:22.20-bookworm-slim

# Native build deps for bcrypt / sharp / canvas etc. (mirrors Dockerfile.dev).
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    python3 \
    bash \
    git \
    ca-certificates \
 && rm -rf /var/lib/apt/lists/*

RUN npm --no-update-notifier --no-fund --global install pnpm@10.6.1

WORKDIR /app
# Modest default heap for one-off node (prisma generate/db push). The entrypoint
# overrides NODE_OPTIONS per watcher (backend needs more, frontend needs less) so the
# backend+frontend pair both fit comfortably under the ~7.7 GB Docker VM.
ENV NODE_OPTIONS="--max-old-space-size=2048"
