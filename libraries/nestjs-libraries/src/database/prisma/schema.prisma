  @@index([activeProvider])
}

// Cost-control spend ledger
model AISpendLog {
  id             String       @id @default(cuid())
  organizationId String?
  userId         String?
  provider       String
  model          String
  scope          String
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  costUsd        Float        @default(0)
  createdAt      DateTime     @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, scope, createdAt])
  @@index([organizationId, createdAt])
  @@index([provider, createdAt])
  @@index([scope, createdAt])
  @@index([userId, createdAt])
}

// Per-org provider config (BYOK scaffold — v3.4.0 stub, v3.5 active, v3.6 full)
model AIOrgProviderConfig {
  id             String       @id @default(cuid())
  organizationId String
  identifier     String
  enabled        Boolean      @default(false)
  isActive       Boolean      @default(false) // only one can be active per org
  credentials    String?
  defaultModel   String?
  reasoningModel String?
  extraConfig    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, identifier])
  @@index([organizationId])
  @@index([enabled])
  @@index([organizationId, isActive])
}

model OrgShortLinkConfig {
  id             String   @id @default(cuid())
  organizationId String
  identifier     String
  enabled        Boolean  @default(false)
  isActive       Boolean  @default(false)
  credentials    String?
  customDomain   String?
  name           String?
  accountFingerprint String?
  extraConfig    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, identifier, accountFingerprint])
  @@index([organizationId])
  @@index([organizationId, isActive])
}

model ShortLink {
  id             String   @id @default(cuid())
  organizationId String
  provider       String
  shortUrl       String
  originalUrl    String
  providerLinkId String?
  postId         String?
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  snapshots      ShortLinkSnapshot[]

  @@unique([organizationId, shortUrl])
  @@index([organizationId, provider])
  @@index([organizationId, createdAt])
}

model ShortLinkSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  shortLinkId    String
  clicks         Float
  date           DateTime     @db.Date
  createdAt      DateTime     @default(now())
  shortLink      ShortLink    @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([shortLinkId, date])
  @@index([organizationId, date])
}

// ── v3.8.8: Per-user API keys ──
model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  name           String
  hashedKey      String       @unique
  prefix         String
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([hashedKey])
}

// ── v3.8.10: App-level RBAC role. Org-scoped when organizationId is set; NULL = system/template ──
model AppRole {
  id             String           @id @default(uuid())
  organizationId String?
  key            String
  name           String
  description    String?
  isSystem       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  permissions    AppRolePermission[]
  memberships    UserOrganization[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

// ── v3.8.10: Fine-grained capability ──
model Permission {
  id          String           @id @default(uuid())
  resource    String
  action      String
  description String?
  roles       AppRolePermission[]

  @@unique([resource, action])
  @@index([resource])
}

// ── v3.8.10: Join table for roles ↔ permissions ──
model AppRolePermission {
  roleId       String
  permissionId String
  role         AppRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ── v3.8.10: 1:1 profile split from User ──
model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  name              String?
  lastName          String?
  bio               String?
  avatarUrl         String?
  pictureId         String?
  timezone          String?  // IANA tz
  sendSuccessEmails Boolean  @default(true)
  sendFailureEmails Boolean  @default(true)
  sendStreakEmails  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  picture           File?    @relation(fields: [pictureId], references: [id])

  @@index([pictureId])
}

// ── v3.8.10: Login session backing refresh-token rotation ──
model Session {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String    @unique
  previousTokenHash String? // last rotated-out hash — reuse of it revokes the session
  userAgent         String?
  ip                String?
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([previousTokenHash])
}

// ── v3.8.10: Platform-wide login provider config ──
model AuthProviderConfig {
  id            String   @id @default(uuid())
  provider      Provider
  enabled       Boolean  @default(false)
  clientId      String?
  clientSecret  String?
  authUrl       String?
  tokenUrl      String?
  userInfoUrl   String?
  scopes        String?  @default("openid profile email")
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider])
}

// ── v3.8.10: Per-org media provider config ──
model MediaProviderConfig {
  id                  String         @id @default(uuid())
  organizationId      String
  identifier          String
  enabled             Boolean        @default(false)
  credentials         String?        // encrypted
  storageProviderId   String?        // null = LOCAL
  storageRootFolderId String?        // root folder in storage
  accountFingerprint  String?
  extraConfig         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  organization        Organization   @relation(fields: [organizationId], references: [id])
  storageProvider     StorageProviderConfig? @relation(fields: [storageProviderId], references: [id])

  @@unique([organizationId, identifier])
  @@index([organizationId])
}

// Per-org brand voice / custom instructions + localization
model AIBrandProfile {
