  slug              String?
  logoFileIds       Json?        @default("[]")
  palette           Json?        @default("[]")
  fontFamilies      Json?        @default("[]")
  customFonts       Json?        @default("[]")
  introFileId       String?
  outroFileId       String?
  enforcement       Json?        @default("{}")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id])
  posts             Post[]

  @@index([organizationId])
}

// Editable prompt templates — NOT seeded; in-code PROMPT_CONSTANTS is canonical
model AIPromptTemplate {
