  organizationId String?
  globalKey      String?       @unique
  key            String
  content        String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId, key])
  @@index([key])
}

// Append-only audit of AI-settings changes
model AISettingsAudit {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  detail    String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// Media pipeline jobs/artifacts
model AIMediaJob {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  provider       String
  operation      String
  status         String       @default("pending")
  artifactUrl    String?
  provenance     String?
  costUsd        Float        @default(0)
  creditType     String?
  error          String?
  folderId    String?
  model       String?
  versionId   String?
  inputJson   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

// Org prompt library — user-created reusable prompts
model AIPromptLibraryItem {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt])
}

// RAG index — metadata + BM25-text row for each indexed chunk.
// Embeddings live in a SEPARATE out-of-band side table AIContentEmbedding
// created via raw SQL (§3.6). NEVER store vector here — Prisma-managed
// tables get DROPPED by prisma db push --accept-data-loss.
model AIContentIndex {
  id             String       @id @default(cuid())
  organizationId String
  sourceType     String
  sourceId       String
  chunkIndex     Int          @default(0)
  contentHash    String
  chunk          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, sourceType, sourceId, chunkIndex])
  @@index([organizationId])
  @@index([organizationId, updatedAt])
  @@index([organizationId, sourceType, sourceId])
  @@index([contentHash])
}

enum State {
  QUEUE
  PUBLISHED
  ERROR
  DRAFT
}

enum SubscriptionTier {
  STANDARD
  PRO
  TEAM
  ULTIMATE
}

enum Provider {
  LOCAL
  GITHUB
  GOOGLE
  FARCASTER
  WALLET
  GENERIC
}

enum CreationMethod {
  UNKNOWN
  WEB
  MCP
  API
  AUTOPOST
  CLI
}

enum ShortLinkPreference {
  ASK
  YES
  NO
}

enum AnnouncementColor {
  INFO
  WARNING
  ERROR
}

model Announcement {
  id          String            @id @default(uuid())
  title       String
  description String
  color       AnnouncementColor @default(INFO)
  createdAt   DateTime          @default(now())
}

// Multipart upload ledger — tracks ownership and state of multipart uploads
model MultipartUpload {
  id             String   @id @default(uuid())
  organizationId String
  uploadId       String
  key            String
  fileName       String?
  fileHash       String?
  expectedMime   String?
  totalSize      Int?
  partCount      Int      @default(0)
  state          String   @default("created") // created | uploading | completed | failed | aborted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, uploadId])
  @@index([organizationId, state])
  @@index([uploadId])
  @@index([organizationId, uploadId, state])
}

model WatchedAccount {
  id             String   @id @default(uuid())
  organizationId String
  provider       String
  handle         String
  displayName    String?
  enabled        Boolean  @default(true)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  metrics        WatchedAccountMetric[]

  @@unique([organizationId, provider, handle])
  @@index([organizationId])
  @@index([deletedAt])
}

model WatchedAccountMetric {
  id               String   @id @default(uuid())
  watchedAccountId String
  metric           String
  value            Float
  capturedAt       DateTime @default(now())
  watchedAccount   WatchedAccount @relation(fields: [watchedAccountId], references: [id], onDelete: Cascade)

  @@index([watchedAccountId, metric, capturedAt])
}

model Campaign {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  color          String?
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  posts          Post[]
  designs        Design[]

  @@index([organizationId])
  @@index([deletedAt])
}

// Editable design documents — one per org-scoped design
model Design {
  id              String        @id @default(cuid())
  organizationId  String
  name            String
  doc             Json
  width           Int           @default(1080)
  height          Int           @default(1080)
  previewDataUrl  String?
  previewFileId   String?
  createdById     String
  campaignId      String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id])
