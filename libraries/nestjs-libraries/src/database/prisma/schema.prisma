  scopeModels          String?
  fallbackProvider     String?
  fallbackImageProvider String?
  guardrailSettings    String?
  budgetSettings       String?
  rateLimitSettings    String?
  observability        String?
  mcpSettings          String?
  ragSettings          String?
  cacheSettings        String?
  routingSettings      String?
  secretSettings       String?
