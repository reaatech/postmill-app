# Configuration reference: http://docs.postiz.com/configuration/reference
#
# IMPORTANT (v3.7.1): Channel provider credentials and AI provider config are
# no longer read from environment variables. Configure them per-organization
# in-app via Settings → Channels and Settings → AI respectively. The env vars
# listed below are only for infrastructure, SSO login providers, payment gateways,
# and optional integrations.

# === Required Settings
DATABASE_URL="postgresql://postmill-user:postmill-password@localhost:5432/postmill-db-local"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="random string for your JWT secret, make it long"
# ENCRYPTION_KEY=       # Optional: 32-byte base64 or hex key for encrypting secrets at rest. Falls back to JWT_SECRET if unset.
# INTEGRATION_RETURN_URL_ALLOWLIST=   # Optional: comma-separated allowed partner origins for integration/enterprise return URLs (open-redirect allowlist). Unset = no extra origins allowed.
# SSRF_ALLOWED_PRIVATE_CIDRS=         # Optional: comma-separated private CIDRs to allow for self-hosted provider instances (opt-in SSRF exception). Unset = all private/internal ranges blocked.

# === This needs to be exactly the URL you're accessing Postmill on
FRONTEND_URL="http://localhost:4200"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

## Remember to set your public internet IP address in the allow-list for the API token.
##
## Cloudflare is currently required to save things like social media avatars for accounts.
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_ACCESS_KEY="your-access-key"
CLOUDFLARE_SECRET_ACCESS_KEY="your-secret-access-key"
CLOUDFLARE_BUCKETNAME="your-bucket-name"
CLOUDFLARE_BUCKET_URL="https://your-bucket-url.r2.cloudflarestorage.com/"
CLOUDFLARE_REGION="auto"

# === Common optional Settings

## This is a dummy key, you must create your own from Resend.
## If this variable exists, user activation is required.
## If it is commented out, users are activated automatically.
#RESEND_API_KEY="RzeTwHijvxvPUerScFcenUZUALuQJzSaGSMJ"
#EMAIL_FROM_ADDRESS=""
#EMAIL_FROM_NAME=""
#DISABLE_REGISTRATION=false

# Where will social media icons be saved - local or cloudflare.
STORAGE_PROVIDER="local"

# Your upload directory path if you host your files locally, otherwise Cloudflare will be used.
#UPLOAD_DIRECTORY=""

# Your upload directory path if you host your files locally, otherwise Cloudflare will be used.
#NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY=""

# Channel provider credentials are now configured per-org via Settings → Channels.
# No env vars are read for channel/AI provider credentials.

# Login / SSO providers (used for user authentication, not for channel posting)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Google OAuth *login* reuses these (channel Google/Youtube/GMB credentials go in Settings → Channels)
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
# Farcaster (Neynar) *login* only
NEYNAR_SECRET_KEY=""

# Chrome Extension Settings (for cookie-based platform integrations like Skool)
EXTENSION_ID=""

# Misc Settings
NEXT_PUBLIC_DISCORD_SUPPORT=""
NEXT_PUBLIC_POLOTNO=""
# NOT_SECURED=false
API_LIMIT=30 # The limit of the public API hour limit

# Payment settings
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_KEY=""

# Developer Settings
IS_GENERAL="true" # required for now
NEXT_PUBLIC_POSTMILL_OAUTH_DISPLAY_NAME="Authentik"
NEXT_PUBLIC_POSTMILL_OAUTH_LOGO_URL="https://raw.githubusercontent.com/walkxcode/dashboard-icons/master/png/authentik.png"
POSTMILL_GENERIC_OAUTH="false"
POSTMILL_OAUTH_AUTH_URL="https://auth.example.com/application/o/authorize"
POSTMILL_OAUTH_TOKEN_URL="https://auth.example.com/application/o/token"
POSTMILL_OAUTH_USERINFO_URL="https://authentik.example.com/application/o/userinfo"
POSTMILL_OAUTH_CLIENT_ID=""
POSTMILL_OAUTH_CLIENT_SECRET=""
# POSTMILL_OAUTH_SCOPE="openid profile email" # default values

# Short Link Service Settings
# DUB_TOKEN="" # Your self-hosted Dub API token
# DUB_API_ENDPOINT="https://api.dub.co" # Your self-hosted Dub API endpoint
# DUB_SHORT_LINK_DOMAIN="dub.sh" # Your self-hosted Dub domain

# SHORT_IO_SECRET_KEY="" # Your Short.io API secret key

# KUTT_API_KEY="" # Your Kutt.it API key
# KUTT_API_ENDPOINT="https://kutt.it/api/v2" # Your self-hosted Kutt endpoint
# KUTT_SHORT_LINK_DOMAIN="kutt.it" # Your self-hosted Kutt domain

# LINK_DRIP_API_KEY="" # Your LinkDrip API key
# LINK_DRIP_API_ENDPOINT="https://api.linkdrip.com/v1/" # Your self-hosted LinkDrip API endpoint
# LINK_DRIP_SHORT_LINK_DOMAIN="dripl.ink" # Your self-hosted LinkDrip domain

# Analytics
# RUN_CRON="true" # Required on ONE orchestrator instance to run the daily analytics collection workflow
# ANALYTICS_DAILY_RETENTION_DAYS="548" # Keep raw daily channel snapshots this long (~18mo) before weekly rollup
# ANALYTICS_POST_RETENTION_DAYS="90" # Prune per-post daily snapshots older than this
