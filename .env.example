# Configuration reference: http://docs.postiz.com/configuration/reference
#
# IMPORTANT: AI provider config is configured per-organization in-app via
# Settings → AI (no env fallback). Channel (social) OAuth-app credentials support
# BOTH paths: set a provider's platform OAuth app in the environment below to give
# every org one-click "Connect" (no key entry), OR leave it unset and let each org
# bring its own app per-organization via Settings → Channels. A per-org config
# always overrides the platform env app. See the "Channel OAuth apps" block below.

# === Required Settings
DATABASE_URL="postgresql://postmill-user:postmill-password@localhost:5432/postmill-db-local"
# Redis endpoint. For local development the docker-compose.dev.yaml redis service
# listens on redis://localhost:6379 (started automatically by `docker compose up`).
# For Upstash (production) use the TLS URL: rediss://default:<token>@<host>:<port>
REDIS_URL="redis://localhost:6379"
JWT_SECRET="random string for your JWT secret, make it long"
# ENCRYPTION_KEY=       # Optional: 32-byte base64 or hex key for encrypting secrets at rest. Falls back to JWT_SECRET if unset.
# INTEGRATION_RETURN_URL_ALLOWLIST=   # Optional: comma-separated allowed partner origins for integration/enterprise return URLs (open-redirect allowlist). Unset = no extra origins allowed.
# SSRF_ALLOWED_PRIVATE_CIDRS=         # Optional: comma-separated private CIDRs to allow for self-hosted provider instances (opt-in SSRF exception). Unset = all private/internal ranges blocked.

# === This needs to be exactly the URL you're accessing Postmill on
FRONTEND_URL="http://localhost:4200"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

## Storage is now per-tenant (Settings → Storage). The built-in default is LOCAL,
## rooted at UPLOAD_DIRECTORY. Cloud providers (S3/R2/B2/iDriveE2) are configured
## per-organization in-app, not via environment variables.

# === Common optional Settings

## Email provider (v3.8.1+). 6 providers: resend, sendgrid, mailgun, postmark, ses, smtp
## The adapter is selected by EMAIL_PROVIDER; unset/unknown = email is off (users activate automatically)
## If this variable exists and EMAIL_FROM_* are set, user activation is required.
## If it is commented out, users are activated automatically.
#EMAIL_PROVIDER="resend"
#EMAIL_API_KEY=""
#EMAIL_FROM_ADDRESS=""
#EMAIL_FROM_NAME=""
#EMAIL_WEBHOOK_SECRET=""       # Signing secret for the active provider's webhook
## Mailgun only
#EMAIL_MAILGUN_DOMAIN=""
#EMAIL_REGION="us"            # us or eu (Mailgun/SES region)
## Amazon SES only (falls back to AWS_* env vars if present)
#EMAIL_SES_ACCESS_KEY_ID=""
#EMAIL_SES_SECRET_ACCESS_KEY=""
## SMTP only
#EMAIL_SMTP_HOST=""
#EMAIL_SMTP_PORT="587"
#EMAIL_SMTP_SECURE="false"
#EMAIL_SMTP_USER=""
#EMAIL_SMTP_PASS=""
## Retention (optional, default 90 days)
#EMAIL_LOG_RETENTION_DAYS=90
#DISABLE_REGISTRATION=false

## Campaign Hub: number of days after a campaign's endDate before its CampaignItem tags are purged (default 30)
#CAMPAIGN_PURGE_DAYS=30

## Push notifications (FCM v1). Leave all three unset to disable push.
#FCM_PROJECT_ID=""
#FCM_CLIENT_EMAIL=""
#FCM_PRIVATE_KEY=""

# Local storage directory (avatars, app images, media library). Must exist and be writable.
#UPLOAD_DIRECTORY="./uploads"

# Frontend-relative path to the upload directory (for display purposes).
#NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY="uploads"

# Maximum upload file size in bytes (default 1 GB). Used by /media/upload-server.
#MEDIA_UPLOAD_MAX_BYTES=1073741824

# Per-org local storage quota in GB (default 5). Used when the Org record has no quota set.
#LOCAL_STORAGE_QUOTA_GB=5

# === Channel OAuth apps (platform "click-connect")
# Set a provider's OAuth app credentials here and every org connects that channel
# with one click — no per-org key entry. Leave a provider unset to require the org
# to add its own app via Settings → Channels (the "alternatively use keys" path).
# A per-org config always takes precedence over these. All optional.
#X_API_KEY=""
#X_API_SECRET=""
#LINKEDIN_CLIENT_ID=""            # also used for linkedin-page
#LINKEDIN_CLIENT_SECRET=""
#FACEBOOK_APP_ID=""               # also used for instagram (via Facebook login)
#FACEBOOK_APP_SECRET=""
#INSTAGRAM_APP_ID=""              # instagram-standalone (Instagram Login)
#INSTAGRAM_APP_SECRET=""
#DISCORD_CLIENT_ID=""
#DISCORD_CLIENT_SECRET=""
#SLACK_ID=""
#SLACK_SECRET=""
#TIKTOK_CLIENT_ID=""
#TIKTOK_CLIENT_SECRET=""
#PINTEREST_CLIENT_ID=""
#PINTEREST_CLIENT_SECRET=""
#REDDIT_CLIENT_ID=""
#REDDIT_CLIENT_SECRET=""
#TWITCH_CLIENT_ID=""
#TWITCH_CLIENT_SECRET=""
#THREADS_APP_ID=""
#THREADS_APP_SECRET=""
#DRIBBBLE_CLIENT_ID=""
#DRIBBBLE_CLIENT_SECRET=""
#MASTODON_CLIENT_ID=""
#MASTODON_CLIENT_SECRET=""
#MEWE_APP_ID=""
#MEWE_API_KEY=""
#KICK_CLIENT_ID=""
#KICK_SECRET=""
#GOOGLE_GMB_CLIENT_ID=""
#GOOGLE_GMB_CLIENT_SECRET=""
#NEYNAR_CLIENT_ID=""              # wrapcast (Farcaster) channel posting
#VK_ID=""
#WHOP_CLIENT_ID=""
#TELEGRAM_TOKEN=""                # bot token (token-only provider)
# YouTube channel posting reuses YOUTUBE_CLIENT_ID / YOUTUBE_CLIENT_SECRET below.
# Custom OAuth channel reuses POSTMILL_OAUTH_CLIENT_ID / POSTMILL_OAUTH_CLIENT_SECRET.

# Login / SSO providers (used for user authentication, not for channel posting)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Google OAuth *login* reuses these (channel Google/Youtube/GMB credentials go in Settings → Channels)
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
# Farcaster (Neynar) *login* only
NEYNAR_SECRET_KEY=""

# Chrome Extension Settings (for cookie-based platform integrations like Skool)
EXTENSION_ID=""

# Misc Settings
NEXT_PUBLIC_DISCORD_SUPPORT=""

# NOT_SECURED=false
# API_LIMIT=600 # Global per-org hourly request throttle (default 600). Do NOT set 30: the SPA fires 15-30 API calls per page navigation.

# Payment settings
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_KEY=""

# Developer Settings
IS_GENERAL="true" # required for now
NEXT_PUBLIC_POSTMILL_OAUTH_DISPLAY_NAME="Authentik"
NEXT_PUBLIC_POSTMILL_OAUTH_LOGO_URL="https://raw.githubusercontent.com/walkxcode/dashboard-icons/master/png/authentik.png"
POSTMILL_GENERIC_OAUTH="false"
POSTMILL_OAUTH_AUTH_URL="https://auth.example.com/application/o/authorize"
POSTMILL_OAUTH_TOKEN_URL="https://auth.example.com/application/o/token"
POSTMILL_OAUTH_USERINFO_URL="https://authentik.example.com/application/o/userinfo"
POSTMILL_OAUTH_CLIENT_ID=""
POSTMILL_OAUTH_CLIENT_SECRET=""
# POSTMILL_OAUTH_SCOPE="openid profile email" # default values

# Local development feature flags (v3.8.11+)
# Set any of these to "true" or "1" to disable the corresponding subsystem during
# local development. This reduces startup time and memory use when you are not
# working on that feature. All features remain enabled by default.
#DEV_DISABLE_AI=true
#DEV_DISABLE_MCP=true
#DEV_DISABLE_MEDIA=true
#DEV_DISABLE_SHORTLINKS=true
#DEV_DISABLE_EMAIL=true
#DEV_DISABLE_VIDEO=true
#DEV_DISABLE_AGENT=true
#DEV_DISABLE_CRON=true
#DEV_DISABLE_SENTRY=true
#DEV_DISABLE_OPENTELEMETRY=true
# Sentry profiling is opt-in in development. Set to "1" to enable it.
#SENTRY_PROFILING=1
# Frontend browser profiling (`Document-Policy: js-profiling`) is opt-in in dev.
#FRONTEND_PROFILING=1

# Inngest Cloud / Dev Server configuration
# INNGEST_EVENT_KEY="..."           # required for Cloud; omit for local dev server
# INNGEST_SIGNING_KEY="..."         # required for Cloud; omit for local dev server
# INNGEST_SIGNING_KEY_FALLBACK="..." # optional, for key rotation
# INNGEST_ENV="production"          # optional branch environment name
# INNGEST_DEV="1"                   # set to 1 when using local inngest-cli dev server
# INNGEST_BASE_URL="http://localhost:8288" # only for local dev server
# INNGEST_SERVE_ORIGIN="..."        # optional public backend origin
# INNGEST_SERVE_PATH="/api/inngest" # optional
# USE_INNGEST="true"                # feature flag for cutover

# Stock Media APIs (Unsplash photos, Pexels videos, Jamendo audio, Pixabay vectors, GIPHY stickers)
# See docs/operations-guide/configuration.md for details
# Unsplash gives you an Access Key AND a Secret Key — only the Access Key is needed here.
# (The Secret Key is for OAuth on-behalf-of-user actions, which Postmill does not use.)
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
# Pixabay API key for vectors/illustrations (and optionally video/music where enabled).
# Get one at https://pixabay.com/api/docs/. Attribution-on-browse is required while browsing.
PIXABAY_API_KEY=
# GIPHY API key for transparent stickers. The "Powered By GIPHY" mark must render in the picker.
# Get one at https://developers.giphy.com/.
GIPHY_API_KEY=
# Iconify has no API key; per-set open-source licenses are surfaced in the UI.
# Jamendo client ID for stock audio browsing in the video editor.
# Get one at https://devportal.jamendo.com/. When unset, stock audio shows a configuration hint.
JAMENDO_CLIENT_ID=
JAMENDO_CLIENT_SECRET=

# Analytics
# ANALYTICS_DAILY_RETENTION_DAYS="548" # Keep raw daily channel snapshots this long (~18mo) before weekly rollup
# ANALYTICS_POST_RETENTION_DAYS="90" # Prune per-post daily snapshots older than this
